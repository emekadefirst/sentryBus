{
  "name": "sentryBus",
  "module": "index.ts",
  "type": "module",
  "private": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "bundle": "bun build src/index.ts --outdir=dist --target=bun --minify"
  },
  "dependencies": {
    "bullmq": "^5.80.9",
    "ioredis": "^5.11.1",
    "zod": "^4.4.3"
  }
}
