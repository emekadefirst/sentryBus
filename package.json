{
  "name": "sentrybus",
  "version": "1.3.0",
  "description": "General-purpose integration/service bus with per-adapter retry, circuit breaking, and config-driven routing",
  "author": "Victor Chibuogwu Chukemeka <emekadefirst@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sentrybus": "dist/index.js"
  },
  "files": [
    "dist",
    "bus"
  ],
  "keywords": [
    "service-bus",
    "event-driven",
    "bullmq",
    "integration",
    "queue",
    "circuit-breaker",
    "redis",
    "bun"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/emekadefirst/sentryBus.git"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "bundle": "bun build src/index.ts --outdir=dist --target=bun --minify"
  },
  "dependencies": {
    "bullmq": "^5.80.9",
    "ioredis": "^5.11.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
